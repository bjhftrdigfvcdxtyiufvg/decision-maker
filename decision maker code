        weight[y]=float(input())
    score=np.array()
    for z in par:
        print("enter the 1 for yes and 0 for no for parameter ",z)
        score[z]=float(input())
    for a,b in zip(score,weight):
        print("the score for parameter ",a," is ",score[a]*weight[a])
    total_score=np.sum(score*weight)
    if total_score>thres:
        print("the decision is yes")
